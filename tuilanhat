-- ============================================================
-- GHOST SYSTEM
-- Fixed: tries both InvokeServer and FireServer on equip
-- Fixed: re-equips every 2s if tool got knocked off mid-chase
-- ============================================================
local function equipSwatter()
    local char = player.Character
    local hum  = char and char:FindFirstChild("Humanoid")
    if hum and player:FindFirstChild("Backpack") then
        local tool = player.Backpack:FindFirstChild(SWATTER_TYPE)
        if tool then
            hum:EquipTool(tool)
            return
        end
    end
    pcall(function() equipRemote:InvokeServer(SWATTER_TYPE, 0) end)
    pcall(function() equipRemote:FireServer(SWATTER_TYPE, 0) end)
end

local function isSwatterEquipped()
    local char = player.Character
    if not char then return false end
    local tool = char:FindFirstChildWhichIsA("Tool")
    return tool ~= nil and tool.Name == SWATTER_TYPE
end

local function findGhost()
    local best, bestDist = nil, math.huge
    for _, obj in pairs(workspace:GetChildren()) do
        if obj:IsA("Model") and string.match(obj.Name, "^FastGhost_%d+$") then
            local pivot = obj:GetPivot()
            if pivot then
                if pivot.Position.Y < GHOST_MIN_Y then
                    continue
                end
                local dist = (pivot.Position - rootPart.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    best     = obj
                end
            end
        end
    end
    return best
end

local function startGhostLoop()
    if ghostLoopRunning then return end
    ghostTarget      = nil
    ghostHitting     = false
    candyChecking    = false
    lastReequipTime  = 0

    stopFly()
    equipSwatter()
    task.wait(1)

    ghostLoopRunning = true
    ghostRayParams.FilterDescendantsInstances = {character}

    ghostHeartbeat = RunService.Heartbeat:Connect(function()
        if not ghostLoopRunning or not ENABLED.ghost then
            ghostHitting = false
            return
        end

        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        if not ghostTarget or not ghostTarget.Parent then
            ghostTarget  = findGhost()
            ghostHitting = false
            if not ghostTarget then
                root.Velocity = Vector3.zero
                return
            end
            equipSwatter()
        end

        local pivot = ghostTarget:GetPivot()
        if pivot and pivot.Position.Y < GHOST_MIN_Y then
            ghostTarget  = nil
            ghostHitting = false
            root.Velocity = Vector3.zero
            return
        end

        local currentPos = root.Position
        local targetPos  = ghostTarget:GetPivot().Position
        local direction  = (targetPos - currentPos)
        local distance   = direction.Magnitude

        if distance > 0.1 then direction = direction.Unit
        else direction = Vector3.zero end

        local moveDir = direction * ghostFlySpeed

        if distance > 0.1 then
            local result = workspace:Raycast(currentPos, direction * dodgeDistance, ghostRayParams)
            if result then
                local right = direction:Cross(Vector3.new(0, 1, 0)).Unit
                local left  = -right
                if not workspace:Raycast(currentPos, (direction + left * 0.7).Unit * dodgeDistance, ghostRayParams) then
                    moveDir = (direction + left * 0.85).Unit * ghostFlySpeed
                elseif not workspace:Raycast(currentPos, (direction + right * 0.7).Unit * dodgeDistance, ghostRayParams) then
                    moveDir = (direction + right * 0.85).Unit * ghostFlySpeed
                else
                    moveDir = (direction + Vector3.new(0, 0.8, 0)).Unit * ghostFlySpeed
                end
            end
        end

        if distance < 8 then
            local heightDiff = currentPos.Y - targetPos.Y
            if heightDiff > 4 then
                moveDir = moveDir * 0.6 + Vector3.new(0, -35, 0)
            end
        end

        root.Velocity = moveDir

        if distance <= chaseDistance then
            if not ghostHitting then
                ghostHitting  = true
                ghostHitStart = tick()
                equipSwatter()
            end

            local now = tick()

            if now - lastReequipTime >= 2 then
                lastReequipTime = now
                if not isSwatterEquipped() then
                    equipSwatter()
                end
            end

            if (now - ghostHitStart) < 120 then
                if (now - lastHitTime) >= hitCooldown then
                    lastHitTime = now

                    if not candyChecking then
                        candyChecking = true
                        local candyBefore = getCandyCount()
                        pcall(function() swatterRemote:FireServer() end)
                        task.spawn(function()
                            task.wait(0.5)  -- candy check delay (0.5s)
                            local candyAfter = getCandyCount()
                            if candyAfter > candyBefore then
                                ghostHitting = false
                                ghostTarget  = nil
                                task.wait(1.5)  -- ghost cooldown (1.5s)
                            end
                            candyChecking = false
                        end)
                    else
                        pcall(function() swatterRemote:FireServer() end)
                    end
                end
            else
                ghostHitting = false
                ghostTarget  = nil
            end
        else
            if ghostHitting then
                ghostHitting = false
            end
        end

        if root.Position.Y - targetPos.Y > 6 and distance < 5 then
            root.CFrame = root.CFrame * CFrame.new(0, -1.5, 0)
        end
    end)
end

local function stopGhostLoop()
    ghostLoopRunning = false
    ghostHitting     = false
    ghostTarget      = nil
    candyChecking    = false
    if ghostHeartbeat then
        ghostHeartbeat:Disconnect()
        ghostHeartbeat = nil
    end
end

