local function claimSpringEvent()
    if not ENABLED.springEvent then return end
    
    local now = tick()
    if now - springEventLastExecution < SPRING_EVENT_COOLDOWN then
        return
    end
    
    pcall(function()
        local args = {
            {
                Action = "DeliverQuest",
                QuestIndex = 1
            }
        }
        
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("SpecialEvent"):FireServer(unpack(args))
        springEventExecutionCount += 1
        springEventLastExecution = now
    end)
end

-- ============================================================
-- TACO FARM
-- ============================================================
local function flyToTaco(obj)
    if not obj or not obj.Parent then return false end
    
    local part = getBasePart(obj)
    if not part then return false end
    
    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return false end
    
    if not flying then startFly() end
    teleportTo(part.Position + Vector3.zero)
    task.wait(0.1)
    firePrompt(prompt, 0)
    task.wait(0.5)
    
    tacoCollected += 1
    return true
end

local function startTacoLoop()
    if tacoLoopActive then return end
    tacoLoopActive = true
    task.spawn(function()
        while tacoLoopActive and ENABLED.taco do
            local found = 0
            for _, obj in ipairs(workspace:GetChildren()) do
                if not tacoLoopActive or not ENABLED.taco then break end
                if isHoneypot(obj) then continue end
                
                local num = tonumber(obj.Name)
                if not num then continue end
                
                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                if not prompt then continue end
                
                local part = getBasePart(obj)
                if not part then
                    if obj:IsA("BasePart") then part = obj end
                end
                if not part then continue end
                
                found += 1
                tacoCurrentIndex = num
                flyToTaco(obj)
            end
            
            if found == 0 then
                task.wait(2)
            end
        end
        
        tacoLoopActive = false
    end)
end

local function stopTacoLoop()
    tacoLoopActive = false
end

