-- SPAWN PART COLLECTOR
-- ============================================================
local spawnCollectorActive = false

local function startSpawnCollector()
    if spawnCollectorActive then return end
    spawnCollectorActive = true
    task.spawn(function()
        local seen = {}

        while spawnCollectorActive do
            task.wait(0.5)

            for _, obj in ipairs(workspace:GetDescendants()) do
                if SPAWN_PARTS[obj.Name] and not isHoneypot(obj) and not seen[obj] then
                    local part   = getBasePart(obj)
                    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
