local dailySpinLoopActive = false

local function runDailySpin()
    if not ENABLED.dailySpin or not dailySpinLoopActive then return end
    pcall(function()
        local args = {
            "spin",
            "daily"
        }
        ReplicatedStorage:WaitForChild("Events"):WaitForChild("DailySpin"):FireServer(unpack(args))
        dailySpinCount += 1
    end)
end

-- ============================================================
-- CONSOLIDATED NOCLIP ENFORCER (OPTIMIZED)
-- ============================================================
RunService.Stepped:Connect(function()
    if not character or not humanoid or not humanoid.Parent then return end
    
    if arcadeGodActive or ghostLoopRunning or flying then
        for _, p in ipairs(character:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = false
            end
        end
    end
end)

-- ============================================================
-- MAIN LOOP - ⭐ AUTO-DISABLE FLY WHEN ARCADE ENDS
-- ============================================================
task.spawn(function()
    while true do
        task.wait(1)
        if loopActive then continue end

        local activeEvent = getActiveEvent()

        if activeEvent == "arcade" and lastEvent ~= "arcade" then
            resetTicketState()
        end

        if lastEvent ~= activeEvent then
            if lastEvent == "arcade" then
                stopTicketWatcher()
                arcadeGodActive = false
                resetTicketState()
                
                if flying then
                    stopFly()
                end
            end
            collecting       = false
            collectingTicket = false
            lastEvent        = activeEvent
        end

        if activeEvent == "arcade" and ENABLED.arcade then
            if not flying then startFly() end
            arcadeGodActive = true

            stopGhostLoop()
            startTicketWatcher()
            startSpawnCollector()

            if not collecting then
                loopActive = true
                task.spawn(function()
                    runArcade()
                    loopActive = false
                end)
            end
        else
            arcadeGodActive = false
            stopTicketWatcher()
            stopSpawnCollector()

            if ENABLED.ghost and not ghostLoopRunning then
                startGhostLoop()
            elseif not ENABLED.ghost and ghostLoopRunning then
                stopGhostLoop()
            end
        end

        if not collecting and ENABLED.eggs then
            loopActive = true
            task.spawn(function()
                runEggs()
                loopActive = false
            end)
        end
    end
end)

