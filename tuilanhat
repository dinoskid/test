-- ============================================================
-- TICKET COLLECT
-- ============================================================
local function flyToTicket(part, prompt)
    if not part or not part.Parent then
        return false
    end
    if ticketCapReached then
        return false
    end
    if collectingTicket then
        return false
    end

    collectingTicket = true
    if not flying then startFly() end

    teleportTo(part.Position + Vector3.zero)

    if bv then bv.Velocity = Vector3.zero end
    local settle = jitter(0.5, 0.1)
    task.wait(settle)

    if part and part.Parent and prompt then
        local ok, err = pcall(function() fireproximityprompt(prompt, 0) end)
        local confirm = jitter(0, 0.5)
        task.wait(confirm)

        ticketsCollected += 1

        if ticketsCollected >= MAX_TICKETS then
            ticketCapReached = true
        end

        collectingTicket = false
        return true
    else
        collectingTicket = false
        return false
    end
end

-- ============================================================
-- COLLECT ITEM  (eggs)
-- ============================================================
local function collectItem(part, prompt, label, holdDuration)
    if collecting then return false end
    if not part or not part.Parent then return false end
    collecting = true
    teleportTo(part.Position + Vector3.zero)
    task.wait(0.1)
    if prompt then
        firePrompt(prompt, holdDuration or 0)
        task.wait((holdDuration or 0) + 0.2)
    end
    task.wait(CONFIG.ItemCooldown)
    collecting = false
    return true
end

-- ============================================================
-- ARCADE — ORBS
-- ============================================================
local function collectOrbs()
    if collectingTicket then return end
    local evFolder = workspace:FindFirstChild("Events")
    if not evFolder then return end
    for _, container in ipairs({
        evFolder:FindFirstChild("ArcadeSpheres"),
        evFolder:FindFirstChild("Arcade"),
    }) do
        if container then
            for _, obj in ipairs(container:GetChildren()) do
                if collectingTicket then return end
                if ORB_NAMES[obj.Name] and not isHoneypot(obj) then
                    local part = getBasePart(obj)
                    if part and part.Position.Y >= MIN_Y then
                        teleportTo(part.Position + Vector3.zero)
                        task.wait(0.05)
                    end
                end
            end
        end
    end
end

-- ============================================================
-- ARCADE — TICKETS
-- ============================================================
local function findTickets()
    local tickets = {}
    local evFolder = workspace:FindFirstChild("Events")
    if not evFolder then return tickets end
    for _, container in ipairs(evFolder:GetChildren()) do
        for _, obj in ipairs(container:GetChildren()) do
            if obj.Name == "ArcadeTicket" and not isHoneypot(obj) then
                local part   = getBasePart(obj)
                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                if not prompt then
                    local ui = obj:FindFirstChild("UI")
                    if ui then
                        prompt = ui:FindFirstChildWhichIsA("ProximityPrompt", true)
                    end
                end
                if part and part.Position.Y >= MIN_Y and prompt then
                    table.insert(tickets, { part = part, prompt = prompt })
                end
            end
        end
    end
    return tickets
end

-- ============================================================
-- ARCADE — MAIN ROUTINE
-- ============================================================
local function runArcade()
    if not ticketCapReached then
        local tickets = findTickets()
        for _, t in ipairs(tickets) do
            if not ENABLED.arcade then break end
            if ticketCapReached then break end
            if t.part and t.part.Parent and t.prompt then
                flyToTicket(t.part, t.prompt)
                task.wait(jitter(3,1))
            end
        end
    end
    collectOrbs()
    task.wait(0.3)
end

-- ============================================================
-- TICKET WATCHER
-- ============================================================
local ticketWatcherActive = false

local function startTicketWatcher()
    if ticketWatcherActive then return end
    ticketWatcherActive = true
    task.spawn(function()
        local seenTickets = {}

        while ticketWatcherActive do
            task.wait(0.5)
            if not ENABLED.arcade then continue end

            if not ticketCapReached then
                local tickets = findTickets()
                for _, t in ipairs(tickets) do
                    if ticketCapReached then break end
                    if not seenTickets[t.part] then
                        seenTickets[t.part] = true
                        flyToTicket(t.part, t.prompt)
                        task.wait(jitter(2, 1))  -- reverted to original delay
                        collectOrbs()
                    end
                end

                for part, _ in pairs(seenTickets) do
                    if not part or not part.Parent then
                        seenTickets[part] = nil
                    end
                end
            end
        end

        ticketWatcherActive = false
    end)
end

local function stopTicketWatcher()
    ticketWatcherActive = false
end

