local SPAWN_PARTS = {
    ArcadeTicket   = true,
    LuckyBlockPart = true,
    MeteorEggPart  = true,
    SnowyEggPart   = true,
}
local FLY_SPEED_COLLECT = 50

-- ============================================================
-- FLY-TO-TARGET
-- ============================================================
local function flyToTarget(part, prompt, label)
    if not part or not part.Parent then return false end
    if not flying then startFly() end

    local timeout = 10
    local started = tick()

    while tick() - started < timeout do
        if not part or not part.Parent then
            return false
        end

        local goal = part.Position + Vector3.zero
        local dir  = goal - rootPart.Position
        local dist = dir.Magnitude

        if dist <= 4 then
            if bv then bv.Velocity = Vector3.zero end
            break
        end

        if bv and bg then
            bv.Velocity = dir.Unit * FLY_SPEED_COLLECT
            bg.CFrame   = CFrame.new(Vector3.zero, dir)
        end

        task.wait(0.05)
    end

    if part and part.Parent then
        if prompt then
            task.wait(jitter(1.5, 1.0))
            pcall(function() fireproximityprompt(prompt, 0) end)
            task.wait(jitter(1.2, 0.8))
        end
        return true
    end

    return false
end

